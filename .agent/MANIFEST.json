  "cron_jobs": {
    "hetzner": {
      "source": "/etc/cron.d/tcginvest",
      "jobs": [
        {
          "schedule": "0 9 * * 1",
          "script": "workspace/first_run_v3.py",
          "purpose": "BB pipeline \u2014 weekly Mon 09:00. Updates sets, prices, run_log."
        },
        {
          "schedule": "30 9 * * 1",
          "script": "workspace/score_sets.py",
          "purpose": "AI scoring \u2014 weekly Mon 09:30. Writes to scores table. DEPENDS ON first_run_v3."
        },
        {
          "schedule": "0 10 1 * *",
          "script": "workspace/generate_blog_posts.py",
          "purpose": "Blog post generator \u2014 monthly 1st 10:00. DEPENDS ON first_run_v3."
        },
        {
          "schedule": "0 21 * * *",
          "script": "workspace/tcgcsv_daily.py",
          "purpose": "TCGCSV daily price ingestion \u2014 21:00. Writes to tcgcsv_prices. PRIMARY DATA SOURCE."
        },
        {
          "schedule": "15 9 * * *",
          "script": "workspace/check_alerts.py",
          "purpose": "Price alerts checker \u2014 daily 09:15. Reads price_alerts, writes triggered flag."
        },
        {
          "schedule": "15 9 * * *",
          "script": "workspace/send_digest.py",
          "purpose": "Watchlist digest email \u2014 daily 09:15. Gates internally by digest_frequency. Reads watchlist/etb_watchlist/chase_watchlist."
        },
        {
          "schedule": "0 8 * * 0",
          "script": "etb/run_etb_pipeline.py",
          "purpose": "ETB pipeline \u2014 weekly Sun 08:00. Updates etbs, etb_price_snapshots."
        },
        {
          "schedule": "0 6 * * *",
          "script": "chase/fetch_prices_scrape.py",
          "purpose": "Chase card scraper \u2014 daily 06:00. Writes to chase_card_prices. PriceCharting scrape."
        },
        {
          "schedule": "0 22 * * *",
          "script": "workspace/score_heat.py",
          "purpose": "Heat score calculation \u2014 daily 22:00. Writes to set_heat_scores."
        }
      ]
    },
    "paperclip": {
      "source": "crontab -l (user: jaytee)",
      "jobs": [
        {
          "schedule": "0 */6 * * *",
          "script": "~/sync-brain.sh",
          "purpose": "Syncs CLAUDE.md from hetzner to paperclip every 6h."
        },
        {
          "schedule": "*/5 * * * *",
          "script": "~/github-runner/run.sh",
          "purpose": "GitHub Actions self-hosted runner watchdog \u2014 restarts if dead."
        }
      ]
    }
